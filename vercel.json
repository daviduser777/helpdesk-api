{
    "routes": [
        {
            "src": "/",
            "dest": "/public/index.html"
        },
        {
            "src": "/(.*)\\.(html|css|js)",
            "dest": "/public/$1.$2"
        },
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        }
    ]
}
